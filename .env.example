# ─── LLM API (Task 18 classifier) ───
# OpenAI-compatible endpoint + key. Loaded by crypto_analyser.config.load_config()
# and injected into config/settings.yaml's api_keys.llm_api_url / llm_api_key.
# Without these set, settings.yaml still holds the changeme_ placeholder and
# load_config() raises RuntimeError at startup (fail-fast on misconfig).
LLM_API_URL=https://api.example.com/v1
LLM_API_KEY=changeme_llm_api_key

# ─── Optional ───
TELEMETRY_ENABLED=false
POSTGRES_VERSION=17
