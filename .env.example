PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=postgres
PGVECTOR_DB=crypto
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crypto

# OpenAI-compatible chat and embedding API
LLM_API_URL=https://api.example.com/v1
LLM_API_KEY=changeme_llm_api_key
LLM_MODEL=glm-5.2-short
EMBEDDING_MODEL=qwen3-embedding
RAGAS_JUDGE_MODEL=glm-5.2-short

# Optional alternative to `crypto-analyser news load --archive-dir ...`
NEWS_ARCHIVE_DIR=/path/to/free-crypto-news/archive