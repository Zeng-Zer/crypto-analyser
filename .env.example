# ─── pgvector ───
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=changeme_pgvector_password
PGVECTOR_DB=crypto

# ─── Langfuse ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344

# Langfuse Postgres
LANGFUSE_POSTGRES_USER=postgres
LANGFUSE_POSTGRES_PASSWORD=changeme_langfuse_postgres_password
LANGFUSE_POSTGRES_DB=postgres

# Langfuse encryption (generate via: openssl rand -hex 32)
# ENCRYPTION_KEY must be exactly 64 hex characters (256-bit) — replace with: openssl rand -hex 32
SALT=aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344
ENCRYPTION_KEY=aabbccdd11223344aabbccdd11223344aabbccdd11223344aabbccdd11223344

# Langfuse project keys (set after first run, or pre-configure)
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=

# ─── Clickhouse ───
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=changeme_clickhouse_password

# ─── MinIO ───
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=changeme_minio_secret

# ─── Redis ───
REDIS_AUTH=changeme_redis_secret

# ─── Optional ───
TELEMETRY_ENABLED=false
POSTGRES_VERSION=17
