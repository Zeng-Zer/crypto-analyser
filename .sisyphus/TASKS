      import pandas as pd
   import numpy as np

   class ZScoreEngine:
       def compute_rolling_zscore(self, ohlcv_df, window_hours=24):
           # Convert window to number of candles (5-min granularity)
           window_candles = window_hours * 12  # 12 candles per hour

           # Rolling mean and std
           ohlcv_df['rolling_mean'] = ohlcv_df['close'].rolling(window_candles).mean()
           ohlcv_df['rolling_std'] = ohlcv_df['close'].rolling(window_candles).std()

           # Z-score
           ohlcv_df['zscore'] = (ohlcv_df['close'] - ohlcv_df['rolling_mean']) / ohlcv_df['rolling_std']
           return ohlcv_df

       def detect_anomalies(self, ohlcv_df, threshold=2.5):
           anomalies = ohlcv_df[abs(ohlcv_df['zscore']) > threshold]
           return [{
               'timestamp': row['timestamp'],
               'zscore': row['zscore'],
               'severity': min(abs(row['zscore']) / threshold, 5),  # scale 1-5
               'price': row['close']
           } for row in anomalies.to_dict('records')]
