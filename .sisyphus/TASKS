       def generate_batch(self, texts, batch_size=32):
           embeddings = []
           for i in range(0, len(texts), batch_size):
               batch = texts[i:i+batch_size]
               batch_embeddings = self.model.encode(batch)
               embeddings.extend(batch_embeddings)
           return embeddings

       def update_postgres_embeddings(self, conn):
           cur = conn.cursor()
           register_vector(conn)
           
           # Fetch all rows without embeddings
           cur.execute("SELECT id, content FROM crypto_news WHERE embedding IS NULL")
           rows = cur.fetchall()
           
           # Generate embeddings in batches
           texts = [row[1] for row in rows]
           embeddings = self.generate_batch(texts)
           
           # Update each row with its embedding
           for (id, _), embedding in zip(rows, embeddings):
               cur.execute("""
                   UPDATE crypto_news SET embedding = %s WHERE id = %s
               """, (embedding.tolist(), id))
           
           conn.commit()
