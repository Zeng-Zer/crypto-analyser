1. Create scripts/parse_articles.py:
      import re
   from bs4 import BeautifulSoup
   import psycopg2
   import json

   class ArticleParser:
       def clean_html(self, text):
           # Remove HTML tags
           soup = BeautifulSoup(text, 'html.parser')
           return soup.get_text()

       def normalize_whitespace(self, text):
           # Collapse multiple spaces, remove extra newlines
           return re.sub(r'\s+', ' ', text).strip()

       def chunk_article(self, article, max_chunk_size=500):
           # Strategy: title + description as one chunk, or split long descriptions
           full_text = f"{article['title']}: {article['description']}"
           if len(full_text) <= max_chunk_size:
               return [{
                   'chunk_id': f"{article['link']}_0",
                   'text': full_text,
                   'source': article['source'],
                   'pubDate': article['pubDate']
               }]
           else:
               # Split into multiple chunks
               chunks = []
               for i in range(0, len(full_text), max_chunk_size):
                   chunks.append({
                       'chunk_id': f"{article['link']}_{i}",
                       'text': full_text[i:i+max_chunk_size],
                       'source': article['source'],
                       'pubDate': article['pubDate']
                   })
               return chunks

       def create_table(self, conn):
           cur = conn.cursor()
           cur.execute("""
               CREATE TABLE IF NOT EXISTS crypto_news (
                   id SERIAL PRIMARY KEY,
                   title TEXT,
                   content TEXT,
                   published_at TIMESTAMP,
                   source TEXT,
                   embedding VECTOR(1536),
                   textsearch TSVECTOR GENERATED ALWAYS AS
                       (to_tsvector('english', coalesce(title,'') || ' ' || coalesce(content,''))) STORED
               )
           """)
           conn.commit()

       def insert_chunks(self, conn, chunks):
           cur = conn.cursor()
           for chunk in chunks:
               cur.execute("""
                   INSERT INTO crypto_news (title, content, published_at, source)
                   VALUES (%s, %s, %s, %s)
               """, (chunk['title'], chunk['text'], chunk['pubDate'], chunk['source']))
           conn.commit()
