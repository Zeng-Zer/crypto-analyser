      import requests
   import time
   import feedparser

   class WaybackRSSRetriever:
       def __init__(self, rate_limit=0.8):
           self.rate_limit = rate_limit  # requests per second
           self.last_request_time = 0

       def query_cdx(self, feed_url, start_date, end_date):
           # Throttle: ensure >= 1/rate_limit seconds since last request
           elapsed = time.time() - self.last_request_time
           if elapsed < 1/self.rate_limit:
               time.sleep(1/self.rate_limit - elapsed)

           cdx_url = f"http://web.archive.org/cdx/search/cdx?url={feed_url}*&from={start_date}&to={end_date}&output=json&limit=100"
           response = requests.get(cdx_url)
           self.last_request_time = time.time()
           return response.json()

       def download_snapshot(self, snapshot_url):
           # Download archived RSS XML from Wayback
           response = requests.get(snapshot_url)
           return feedparser.parse(response.content)

       def extract_articles(self, rss_feed):
           articles = []
           for entry in rss_feed.entries:
               articles.append({
                   'title': entry.title,
                   'description': entry.description,
                   'pubDate': entry.published,
                   'link': entry.link
               })
           return articles
