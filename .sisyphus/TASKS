      import psycopg2
   import numpy as np

   class RAGRetriever:
       def hybrid_search(self, query_embedding, query_text, anomaly_timestamp, top_k=10):
           conn = psycopg2.connect("postgres://localhost:5432/crypto")
           cur = conn.cursor()

           # Time-bounded query: articles within +/- 12h of anomaly
           start_time = anomaly_timestamp - pd.Timedelta('12h')
           end_time = anomaly_timestamp + pd.Timedelta('12h')

           # Vector search (semantic)
           cur.execute("""
               SELECT id, title, content, published_at, source,
                      1 - (embedding <=> %s) AS vector_score
               FROM crypto_news
               WHERE published_at BETWEEN %s AND %s
               ORDER BY embedding <=> %s
               LIMIT 20
           """, (query_embedding, start_time, end_time, query_embedding))
           vector_results = cur.fetchall()

           # Keyword search (BM25 via tsvector)
           cur.execute("""
               SELECT id, title, content, published_at, source,
                      ts_rank_cd(textsearch, query) AS keyword_score
               FROM crypto_news, plainto_tsquery('english', %s) query
               WHERE textsearch @@ query
                 AND published_at BETWEEN %s AND %s
               ORDER BY ts_rank_cd(textsearch, query) DESC
               LIMIT 20
           """, (query_text, start_time, end_time))
           keyword_results = cur.fetchall()

           # RRF fusion: score = 1/(k + vector_rank) + 1/(k + keyword_rank)
           # k=60 is standard
           return self._rrf_fusion(vector_results, keyword_results, k=60, top_k=top_k)

       def _rrf_fusion(self, vector_results, keyword_results, k=60, top_k=10):
           # Combine rankings using RRF
           combined_scores = {}

           for rank, (id, title, content, ...) in enumerate(vector_results, 1):
               combined_scores[id] = combined_scores.get(id, 0) + 1/(k + rank)

           for rank, (id, title, content, ...) in enumerate(keyword_results, 1):
               combined_scores[id] = combined_scores.get(id, 0) + 1/(k + rank)

           # Sort by combined score
           sorted_results = sorted(combined_scores.items(), key=lambda x: x[1], reverse=True)
           return sorted_results[:top_k]
