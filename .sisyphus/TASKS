      import psycopg2
   from pgvector.psycopg2 import register_vector

   class IndexCreator:
       def __init__(self, conn):
           self.conn = conn
           register_vector(conn)

       def create_indexes(self):
           cur = self.conn.cursor()
           cur.execute("""
               CREATE INDEX IF NOT EXISTS crypto_news_embedding_idx 
               ON crypto_news USING hnsw (embedding vector_cosine_ops)
               WITH (m=16, ef_construction=64);
               
               CREATE INDEX IF NOT EXISTS crypto_news_textsearch_idx 
               ON crypto_news USING gin(textsearch);
               
               CREATE INDEX IF NOT EXISTS crypto_news_published_idx 
               ON crypto_news (published_at DESC);
           """)
           self.conn.commit()

       def test_vector_search(self, sample_embedding):
           cur = self.conn.cursor()
           cur.execute("""
               SELECT id, title, content, published_at, source,
                      1 - (embedding <=> %s) AS similarity
               FROM crypto_news
               ORDER BY embedding <=> %s
               LIMIT 5
           """, (sample_embedding, sample_embedding))
           return cur.fetchall()

